# ==========================================
# Silvasonic Environment Configuration
# ==========================================
# Copy this file to .env and adjust values as needed.
#
# Variable Categories:
# 1. System Paths - Essential for setup
# 2. General Settings - Mode and networking
# 3. Database Secrets - Change for production!
# 4. Icecast Secrets - Change for production!
# 5. Service Defaults - Can usually be left alone
# ==========================================

# --- 1. System Paths ---
# The path where Silvasonic will store its persistent data (logs, database, recordings).
# Ensure this directory exists and your user has read/write permissions.
# Default: ./workspace
SILVASONIC_WORKSPACE_PATH=./workspace

# --- 2. General Settings ---
# Domain name for the Gateway/Caddy service.
# Use 'localhost' for local development or your valid domain name.
DOMAIN_NAME=localhost

# Enable development mode (verbose logging, autoreload, skipped security checks).
# Set to 'false' for production.
DEV_MODE=true

# --- 3. Database Secrets ---
# PostgreSQL credentials. Ensure these match if you are connecting to an existing DB.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=silvasonic

# --- 4. Icecast Secrets ---
# Passwords for the streaming server.
# IMPORTANT: Change these from 'hackme' for any non-local deployment!
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=hackme
ICECAST_PASSWORD=hackme
ICECAST_RELAY_PASSWORD=hackme

# --- 5. Service Defaults ---
# Icecast Metadata
ICECAST_HOSTNAME=silvasonic
ICECAST_LOCATION="Silvasonic Station"
ICECAST_ADMIN=admin@silvasonic.local

# Recorder Hardware Settings
# Microphone Profile (see services/recorder/config/profiles for options)
MIC_PROFILE=ultramic_384_evo
MIC_NAME=default
