# ==============================================================================
# Silvasonic - Environment Variables
# ==============================================================================
# Copy to .env and adjust values for your local setup.
#
# Section order follows the service dependency chain:
# Infrastructure (Global, DB, Redis) -> Tier 1 (Controller, Processor, Web)
# -> Tier 2 (Recorder) -> Future -> Dev/Test


# ==============================================================================
# 1. General / Global
# ==============================================================================

# Container engine: Podman (see ADR-0004, ADR-0013)
# No override needed - Podman is the only supported engine.

# Development mode
#   True  = rich logging (colors, nice tracebacks)
#   False = JSON logging (production / container aggregation)
SILVASONIC_DEVELOPMENT_MODE=True

# Repository root (absolute path on the host)
SILVASONIC_REPO_PATH=/mnt/data/dev/apps/silvasonic

# Shared workspace root - bind-mounted into service containers
SILVASONIC_WORKSPACE_PATH=/mnt/data/dev_workspaces/silvasonic/

# Podman socket (mounted into Controller for Tier 2 management, see ADR-0013)
# Adjust the user ID (1000) if necessary.
SILVASONIC_PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# Network name for Tier 2 containers (must match compose.yml network name)
SILVASONIC_NETWORK=silvasonic-net

# Testcontainers compatibility socket
DOCKER_HOST=unix:///run/user/1000/podman/podman.sock

# Heartbeat publish interval (seconds) - applies to all services.
# Lower = faster dashboard updates, higher = less Redis traffic.
# Typical values: 5 (responsive), 10 (balanced), 30 (battery-saving).
# SILVASONIC_HEARTBEAT_INTERVAL_S=10


# ==============================================================================
# 2. Database (TimescaleDB / PostgreSQL)
# ==============================================================================
POSTGRES_USER=silvasonic
POSTGRES_PASSWORD=silvasonic
POSTGRES_DB=silvasonic
SILVASONIC_DB_PORT=5432


# ==============================================================================
# 3. Redis (Pub/Sub broker)
# ==============================================================================
SILVASONIC_REDIS_PORT=6379
SILVASONIC_REDIS_URL=redis://localhost:6379/0


# ==============================================================================
# 4. Controller (API / Orchestration)
# ==============================================================================
SILVASONIC_CONTROLLER_PORT=9100

# Reconciliation loop interval (seconds). How fast the controller reacts
# to device changes.  Default: 1.0 (responsive).  Increase to reduce CPU.
# SILVASONIC_RECONCILE_INTERVAL_S=1.0

# Database/Podman health check interval (seconds).  Default: 10.
# SILVASONIC_CONTROLLER_MONITOR_POLL_INTERVAL_S=10

# Log forwarder container poll interval (seconds).  Default: 1.0.
# SILVASONIC_LOG_FORWARDER_POLL_INTERVAL_S=1.0


# ==============================================================================
# 5. Processor (Data Ingestion & Retention)
# ==============================================================================
SILVASONIC_PROCESSOR_PORT=9200


# ==============================================================================
# 6. Web-Mock (Dev UI) & DB-Viewer
# ==============================================================================
SILVASONIC_WEB_MOCK_PORT=8001

# DB-Viewer (Interim Dev UI) is active by default in development.
# If you want to disable it completely, set this to false:
# SILVASONIC_DB_VIEWER_RUN=false


# ==============================================================================
# 7. Recorder (Audio Capture - Tier 2, managed by Controller)
# ==============================================================================
# No host port exposure -- Tier 2 containers are reached via container-internal IP.
# Health endpoint (9500) is accessible within silvasonic-net only.
# SILVASONIC_RECORDER_PORT=9500

# Container image for spawned Recorder instances (set by Controller).
# SILVASONIC_RECORDER_IMAGE=localhost/silvasonic_recorder:latest

# Podman restart policy: max consecutive restart attempts (Level 2 recovery).
# After this many failures, Podman stops restarting the container.
# SILVASONIC_RECORDER_RESTART_MAX_RETRIES=5

# Watchdog exponential backoff base delay (seconds) between FFmpeg restarts.
# Actual delay = base * 2^(attempt-1).  Increase for flaky hardware.
# SILVASONIC_RECORDER_WATCHDOG_BASE_BACKOFF_S=2.0

# Hardware configuration is handled per-instance by the Controller.


# ==============================================================================
# 8. Gateway (Caddy Reverse Proxy)
# ==============================================================================
SILVASONIC_GATEWAY_HTTP_PORT=80
SILVASONIC_GATEWAY_HTTPS_PORT=443
SILVASONIC_DOMAIN_NAME=silvasonic.local


# ==============================================================================
# 9. Cloud Sync (Processor Upload Worker, v0.6.0)
# ==============================================================================
# Optional: If ALL five variables below are set, the Controller seeds them
# into system_config on every startup (encrypted) and enables cloud upload.
# If any variable is missing, cloud sync stays disabled (default).
#
# Supported remote types: webdav, s3, sftp, drive
# For Nextcloud: use remote_type=webdav, URL must end with /remote.php/webdav/
#
# Fernet encryption key — protects cloud credentials at rest in the database.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SILVASONIC_ENCRYPTION_KEY=
#
# SILVASONIC_CLOUD_REMOTE_TYPE=webdav
# SILVASONIC_CLOUD_REMOTE_URL=https://your-storageshare.de/remote.php/webdav/
# SILVASONIC_CLOUD_REMOTE_USER=admin
# SILVASONIC_CLOUD_REMOTE_PASS=your-password-here


# ==============================================================================
# 10. Hardware Tests (just test-hw)
# ==============================================================================
# Profile slug must match a file in services/controller/config/profiles/*.yml.
# The profile YAML contains VID/PID/ALSA match criteria for device detection.

# Primary mic - required for test-hw
SILVASONIC_HW_PRIMARY_PROFILE=ultramic_384_evo

# Secondary mic - optional, enables dual-mic tests
SILVASONIC_HW_SECONDARY_PROFILE=rode_nt_usb
