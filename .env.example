# Silvasonic Environment Variables
# Copy this file to .env and adjust as needed

# ==============================================================================
# Silvasonic – Environment Variables
# ==============================================================================
# Copy to .env and adjust values for your local setup.


# ==============================================================================
# 1. General / Global
# ==============================================================================

# Container engine: Podman (see ADR-0004, ADR-0013)
# No override needed — Podman is the only supported engine.

# Development mode
#   True  → rich logging (colors, nice tracebacks)
#   False → JSON logging (production / container aggregation)
SILVASONIC_DEVELOPMENT_MODE=True

# Repository root (absolute path on the host)
SILVASONIC_REPO_PATH=/mnt/data/dev/apps/silvasonic

# Shared workspace root – bind-mounted into service containers
SILVASONIC_WORKSPACE_PATH=/mnt/data/dev_workspaces/silvasonic/

# Podman socket (mounted into Controller for Tier 2 management, see ADR-0013)
# Adjust the user ID (1000) if necessary.
SILVASONIC_PODMAN_SOCKET=/run/user/1000/podman/podman.sock

# Network name for Tier 2 containers (must match compose.yml network name)
SILVASONIC_NETWORK=silvasonic-net

# Testcontainers compatibility socket
# DOCKER_HOST=unix:///run/user/1000/podman/podman.sock


# ==============================================================================
# 2. Database (TimescaleDB / PostgreSQL)
# ==============================================================================
POSTGRES_USER=silvasonic
POSTGRES_PASSWORD=silvasonic
POSTGRES_DB=silvasonic
SILVASONIC_DB_PORT=5432


# ==============================================================================
# 3. Controller (API / Orchestration)
# ==============================================================================
SILVASONIC_CONTROLLER_PORT=9100


# ==============================================================================
# 4. Redis (Status Bus)
# ==============================================================================
SILVASONIC_REDIS_PORT=6379


# ==============================================================================
# 5. Web-Mock (Dev UI — full UI shell, no DB required)
# ==============================================================================
SILVASONIC_WEB_MOCK_PORT=8001


# ==============================================================================
# 4. Recorder (Audio Capture)
# ==============================================================================
# No host port exposure — Tier 2 containers are reached via container-internal IP.
# Health endpoint (9500) is accessible within silvasonic-net only.
# SILVASONIC_RECORDER_PORT=9500

# Hardware configuration is handled per-instance by the Controller.


# ==============================================================================
# 5. Gateway (Future / Inactive)
# ==============================================================================
# Caddy reverse-proxy – currently not deployed.
# SILVASONIC_GATEWAY_HTTP_PORT=80
# SILVASONIC_GATEWAY_HTTPS_PORT=443


# ==============================================================================
# 6. Uploader (Future / Inactive)
# ==============================================================================
# Cloud synchronisation via Nextcloud (currently unused).
# SILVASONIC_UPLOADER_NEXTCLOUD_URL=https://dummy.your-storageshare.de/remote.php/webdav/
# SILVASONIC_UPLOADER_NEXTCLOUD_USER=admin
# SILVASONIC_UPLOADER_NEXTCLOUD_PASSWORD=testpassword123
