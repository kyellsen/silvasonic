http://{$SILVASONIC_DOMAIN_NAME:silvasonic.local} {
    #tls internal

    # Default: admin / 1234 (bcrypt, generated via `caddy hash-password`)
    basic_auth /* {
        admin $2a$14$b.//IEDTIDhEMk9xFbExbuQKcnoY.HUwtyj1I92QbqkzS89JrnJEG
    }

    log {
        output file /var/log/caddy/access.log
    }

    # Redirect root to Web-Mock (exact match on /)
    redir / /web-mock/

    # Proxy to Web-Mock
    redir /web-mock /web-mock/
    handle_path /web-mock/* {
        reverse_proxy web-mock:8001
    }

    # Proxy to DB Viewer
    redir /db-viewer /db-viewer/
    handle_path /db-viewer/* {
        reverse_proxy db-viewer:8002
    }

    # Proxy to Docs (MkDocs running on host)
    redir /docs /docs/
    handle_path /docs/* {
        reverse_proxy host.containers.internal:8085
    }

    # Proxy live stream to Icecast (Planned)
    # handle /stream/* {
    #     reverse_proxy icecast:8080
    # }
}
