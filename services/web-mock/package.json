{
    "private": true,
    "description": "Tailwind CSS build tooling for silvasonic-web-mock (not published to npm).",
    "scripts": {
        "css:build": "tailwindcss -i ./src/silvasonic/web_mock/static/css/input.css -o ./src/silvasonic/web_mock/static/css/output.css --minify",
        "css:watch": "tailwindcss -i ./src/silvasonic/web_mock/static/css/input.css -o ./src/silvasonic/web_mock/static/css/output.css --watch"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "daisyui": "^5.0.0"
    }
}