FROM python:3.13-slim-bookworm

WORKDIR /app

# 1. Install system dependencies (ADR-0024: FFmpeg as audio engine)
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    libasound2 \
    alsa-utils \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# 2. Get the 'uv' tool directly
COPY --from=ghcr.io/astral-sh/uv:0.10.3 /uv /uvx /bin/

# 3. Copy all code and config at once
COPY pyproject.toml uv.lock ./
COPY packages/ packages/
COPY services/recorder/ services/recorder/

# 4. Install dependencies and code in one go
RUN uv sync --frozen --no-dev --no-editable --package silvasonic-recorder

# 5. Add virtual environment to PATH
ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

EXPOSE 9500

ENTRYPOINT ["python", "-m"]
CMD ["silvasonic.recorder"]