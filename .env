# ==========================================
# Silvasonic Environment Configuration
# ==========================================

# --- 1. System Paths ---
# The path where Silvasonic will store its persistent data.
SILVASONIC_WORKSPACE_PATH=/mnt/data/dev_workspaces/silvasonic

# --- 2. General Settings ---
DOMAIN_NAME=localhost
DEV_MODE=true

# --- 3. Database Secrets ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=silvasonic

# --- 4. Icecast Secrets ---
ICECAST_SOURCE_PASSWORD=hackme
ICECAST_ADMIN_PASSWORD=hackme
ICECAST_PASSWORD=hackme
ICECAST_RELAY_PASSWORD=hackme

# --- 5. Service Defaults ---
ICECAST_HOSTNAME=silvasonic
ICECAST_LOCATION="Silvasonic Station"
ICECAST_ADMIN=admin@silvasonic.local

# Recorder Hardware Settings
MIC_PROFILE=ultramic_384_evo
MIC_NAME=default
