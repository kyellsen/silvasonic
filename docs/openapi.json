  "components": {
    "schemas": {
      "DeviceResponse": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "description": "Logical name of the device"
          },
          "enrollment_status": {
            "type": "string",
            "title": "Enrollment Status",
            "description": "pending, enrolled, or ignored"
          },
          "profile_slug": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Profile Slug",
            "description": "Linked microphone profile"
          },
          "serial_number": {
            "type": "string",
            "title": "Serial Number"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "last_seen": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "title": "Last Seen"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
          }
        },
        "type": "object",
        "required": [
          "name",
          "enrollment_status",
          "serial_number",
          "model",
          "status",
          "last_seen",
          "enabled",
          "config"
        ],
        "title": "DeviceResponse",
        "description": "Full Device response."
      },
      "DeviceUpdate": {
        "properties": {
          "enrollment_status": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^(pending|enrolled|ignored)$"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enrollment Status"
          },
          "profile_slug": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Profile Slug"
          },
          "logical_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Logical Name"
          },
          "enabled": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ],
            "title": "Enabled"
          }
        },
        "type": "object",
        "title": "DeviceUpdate",
        "description": "Payload for updating a device state."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ProfileCreate": {
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-_]+$",
            "title": "Slug"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "match_pattern": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Match Pattern"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
          }
        },
        "type": "object",
        "required": [
          "slug",
          "name",
          "config"
        ],
        "title": "ProfileCreate",
        "description": "Payload for creating a new profile."
      },
      "ProfileResponse": {
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-_]+$",
            "title": "Slug"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "match_pattern": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Match Pattern"
          },
          "config": {
            "additionalProperties": true,
            "type": "object",
            "title": "Config"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "is_system": {
            "type": "boolean",
            "title": "Is System"
          }
        },
        "type": "object",
        "required": [
          "slug",
          "name",
          "config",
          "is_system"
        ],
        "title": "ProfileResponse",
        "description": "Full Profile response."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
